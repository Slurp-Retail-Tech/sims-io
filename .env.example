# Prefer DATABASE_URL if set; otherwise MYSQL_* vars are used.
DATABASE_URL=

# MySQL configuration
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=sims
MYSQL_PASSWORD=sims-password
MYSQL_DATABASE=sims-local
MYSQL_CONNECTION_LIMIT=10
MYSQL_CONNECT_TIMEOUT_MS=10000

# POS API (merchant import)
POS_API_EMAIL=email@example.com
POS_API_PASSWORD=password
POS_AUTH_URL=https://api.getslurp.com/api/login
POS_API_BASE_URL=https://api.getslurp.com
POS_IMPORT_URL=https://api.getslurp.com/api/franchise-retrieve/
POS_BRANCH_URL=https://api.getslurp.com/api/branch
POS_MERCHANT_ID_BASE_URL=https://api.getslurp.com/
POS_CATEGORY_BUSINESS_BASE_URL=https://api.getslurp.com

# Scheduler/API security
MERCHANT_IMPORT_CRON_SECRET=
CLICKUP_SYNC_CRON_SECRET=

# Redis (rate limiting)
# Required in production — in-memory fallback is used for local dev only.
# Password-only Redis URLs need an empty username slot:
# REDIS_URL=redis://:password@redis-host:6379/0
# Redis ACL URLs can include a username:
# REDIS_URL=redis://username:password@redis-host:6379/0
REDIS_URL=redis://localhost:6379
# Set to any non-empty value when the app runs behind a trusted reverse proxy
# (e.g. Coolify, Nginx). Enables reading the real client IP from x-forwarded-for.
# Leave empty if the app is exposed directly to the internet.
TRUSTED_PROXY=

# ClickUp
CLICKUP_API_TOKEN=
CLICKUP_LIST_ID=
CLICKUP_API_BASE_URL=https://api.clickup.com/api/v2
NEXT_PUBLIC_CLICKUP_ENABLED=true
# Optional custom field mapping for ClickUp task request approvals.
# Set each *_ID to your ClickUp custom field id.
# For dropdown-type fields, set *_OPTION_MAP as JSON:
# {"Display Value":"clickup_option_id"}
CLICKUP_CUSTOM_FIELD_PRODUCT_ID=
CLICKUP_CUSTOM_FIELD_PRODUCT_OPTION_MAP=
CLICKUP_CUSTOM_FIELD_DEPARTMENT_REQUEST_ID=
CLICKUP_CUSTOM_FIELD_DEPARTMENT_REQUEST_OPTION_MAP=
CLICKUP_CUSTOM_FIELD_OUTLET_NAME_ID=
CLICKUP_CUSTOM_FIELD_OUTLET_NAME_OPTION_MAP=
CLICKUP_CUSTOM_FIELD_PIC_NAME_ID=
CLICKUP_CUSTOM_FIELD_PIC_NAME_OPTION_MAP=
CLICKUP_CUSTOM_FIELD_PRIORITY_LEVEL_ID=
CLICKUP_CUSTOM_FIELD_PRIORITY_LEVEL_OPTION_MAP=
CLICKUP_CUSTOM_FIELD_SEVERITY_LEVEL_ID=
CLICKUP_CUSTOM_FIELD_SEVERITY_LEVEL_OPTION_MAP=

# Google Workspace SMTP (demo lead email notification + auth emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@getslurp.com
SMTP_FROM_NAME=SIMS
APP_BASE_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_WORKSPACE_DOMAINS=getslurp.com
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=
GOOGLE_CALENDAR_REFRESH_TOKEN=
# Local fallback only. Prefer OAuth refresh-token credentials above.
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_PLACES_ENABLED=false
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_REGION_CODES=MY

# MinIO (file storage)
MINIO_ENDPOINT=http://127.0.0.1:9002
MINIO_PUBLIC_URL=http://127.0.0.1:9002
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=attachments
MINIO_REGION=us-east-1

# Support form (public)
NEXT_PUBLIC_SUPPORT_PHONE=
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
SUPPORTFORM_WHATSAPP_NUMBER=601156654761
DEMOFORM_WHATSAPP_NUMBER=601156654761
# Legacy fallback only (use SUPPORTFORM_WHATSAPP_NUMBER / DEMOFORM_WHATSAPP_NUMBER instead)
NEXT_PUBLIC_SUPPORT_CONTACT=
NEXT_PUBLIC_SUPPORT_WHATSAPP=601156654761

# Demo form reCAPTCHA (optional but recommended for public form protection)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Google Tag Manager (optional). When set, the GTM container loads site-wide and
# the demo form pushes a `demo_form_submit` event to the dataLayer on success.
# Leave blank to disable GTM entirely. Format: GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=

# Meta (Facebook) Pixel (optional). When set, the base pixel loads site-wide
# (PageView) and the demo form fires a `Lead` conversion on success. This is the
# single source of the Lead event — do NOT also configure a Lead tag in GTM or
# Facebook will double-count. Leave blank to disable. Format: numeric Pixel ID.
NEXT_PUBLIC_META_PIXEL_ID=

# Default country code for the "Open in WhatsApp" button in the lead-assigned
# email. Lead phone numbers are stored digits-only; if a number starts with 0 it
# is treated as a local number and this code replaces the leading 0 (e.g.
# 0123456789 -> 60123456789). Defaults to 60 (Malaysia) when unset.
LEAD_WHATSAPP_COUNTRY_CODE=60

# CSAT Google Review trigger (public CSAT survey)
# Company-wide Google review URL for Slurp Retail Tech Sdn Bhd. Shown after a CSAT
# submission when the Support Service rating is Satisfied/Very Satisfied. Leave blank
# to disable the review prompt entirely.
CSAT_GOOGLE_REVIEW_URL=
